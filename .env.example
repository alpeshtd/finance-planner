# Backend environment variables
# Copy this to backend/.env (or set these as environment variables in your deploy target)

# Database URL (Railway provides this for PostgreSQL; defaults to SQLite locally)
# DATABASE_URL=postgresql://user:pass@host:port/dbname
DATABASE_URL=sqlite:///./finance.db

# Which origins are allowed to call the API (comma-separated list)
ALLOWED_ORIGINS=http://localhost:5173

# Port is set by the platform in production (e.g. Railway, Heroku, Render)
# PORT=8000
